<Page x:Class="TripRadar.FlightsResultsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TripRadar"
      mc:Ignorable="d" 
      d:DesignHeight="550" d:DesignWidth="1100"
      Title="FlightsResultsPage">

    <Grid>
        <ScrollViewer>
            <ItemsControl Name="FlightsItemControl" Foreground="White" Width="1000" Background="#FF2C3848" Margin="10,0,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#FF445F7E" CornerRadius="10" Margin="10,5" Padding="15">
                            <StackPanel>
                            <Image Source="{Binding AirlineLogo}" Width="80" Height="80" Margin="0,0,15,0"/>
                            <StackPanel Margin="5">
                            <TextBlock Text="{Binding DepartureAirport, StringFormat='Departure: {0}'}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding ArrivalAirport, StringFormat='Arrival: {0}'}" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="{Binding DepartureTime, StringFormat='Departure Date: {0}'}" Foreground="#FF5AFFE7"/>
                            <TextBlock Text="{Binding ArrivalTime, StringFormat='Return Date: {0}'}" Foreground="#FF5AFFE7"/>
                            <TextBlock Text="{Binding Price, StringFormat='€{0}'}" Foreground="#FF5AFFE7" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                            </StackPanel>
                        </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        </ScrollViewer>
        
    </Grid>
</Page>
