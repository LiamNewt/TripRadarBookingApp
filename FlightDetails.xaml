<Window x:Class="TripRadar.FlightDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TripRadar"
        mc:Ignorable="d"
        Title="Flight Details" Height="700" Width="600" Background="#3f8a88" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid>
        <ScrollViewer>
            <ItemsControl Name="FlightDetailsPage">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF445F7E" CornerRadius="10" Margin="10,5" Padding="15">
                            <StackPanel>
                                <Image Source="{Binding AirlineLogo}" Width="100" Height="100" Margin="0,0,0,0"/>
                                <TextBlock Text="{Binding ArrivalCity, StringFormat='Your Trip To {0}'}" FontFamily="Calibri" FontStyle="Italic" FontWeight="Bold" FontSize="36" Foreground="White" HorizontalAlignment="Left"/>
                                <TextBlock Text="{Binding FlightNum, StringFormat='Flight No: {0}'}" FontSize="18" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Left"/>

                                <StackPanel Orientation="Vertical">
                                    <Border Background="#1A2A3A" CornerRadius="10"  Padding="10" Margin="5">
                                        <StackPanel>
                                            <TextBlock Text="OUTBOUND" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Left"/>
                                            <Image Source="{Binding SmallAirlineLogo}" Height="50" Width="50" Margin="0,0,0,0" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding DepartureAirport, StringFormat='Departure Airport: {0}'}"  FontSize="14" Foreground="White" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding DepartureTime, StringFormat='Departure Date/Time: {0}'}" FontSize="14" FontStyle="Italic" Foreground="#FF5AFFE7" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ArrivalAirport, StringFormat='Arrival Airport: {0}'}" FontSize="14" Foreground="White" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ArrivalTime, StringFormat='Arrival Date/Time: {0}'}" FontSize="14" FontStyle="Italic" Foreground="#FF5AFFE7" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding CabinClass, StringFormat=' {0}'}" FontSize="14" Foreground="White" FontWeight="Bold" FontFamily="Calibri" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#1A2A3A" CornerRadius="10" Padding="10" Margin="5" Visibility="{Binding IsReturn, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="RETURN" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Left"/>
                                            <Image Source="{Binding SmallAirlineLogo}" Width="50" Height="50" Margin="0,0,0,0" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ReturnDepartureAirport, StringFormat='Departure Airport: {0}'}" FontSize="14" Foreground="White" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ReturnDepartureTime, StringFormat='Departure Date/Time: {0}'}" FontSize="14" FontStyle="Italic" Foreground="#FF5AFFE7" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ReturnArrivalAirport, StringFormat='Arrival Airport: {0}'}" FontSize="14" Foreground="White" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding ReturnArrivalTime, StringFormat='Arrival Date/Time: {0}'}" FontSize="14" FontStyle="Italic" Foreground="#FF5AFFE7" HorizontalAlignment="Left"/>
                                            <TextBlock Text="{Binding CabinClass, StringFormat=' {0}'}" FontSize="14" Foreground="White" FontWeight="Bold" FontFamily="Calibri" HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="#1A2A3A" CornerRadius="10" Padding="10" Margin="5" HorizontalAlignment="Left">
                                            <StackPanel Margin="5">
                                                <TextBlock Text="PRICING" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Left"/>
                                                <TextBlock Text="{Binding Price, StringFormat='Price: €{0}'}" FontSize="24" FontWeight="Bold" Foreground="#FF5AFFE7"/>
                                                <TextBlock Text="ADDITIONAL FEES MAY APPLY WITH EXTRAS" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Left"/>
                                            </StackPanel>
                                        </Border>
                                        
                                        <Border Background="#1A2A3A" CornerRadius="10" Padding="10" Margin="5">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Luggage"
                                                   Width="50"
                                                   Height="58"
                                                   HorizontalAlignment="Left"
                                                   Foreground="#FF5AFFE7"/>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="LUGGAGE" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Left"/>
                                                    <TextBlock Text="{Binding LuggageType, StringFormat='Luggage Type: {0}'}" FontSize="12" FontFamily="Calibri" Foreground="White" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding MaxCarryOn, StringFormat='Max Items: {0}'}" FontSize="12" FontFamily="Calibri" Foreground="White" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding MaxCarryOnWeight, StringFormat='Max Weight: {0}'}" FontSize="12" FontFamily="Calibri" Foreground="White" HorizontalAlignment="Left"/>
                                                    <TextBlock Text="{Binding WeightUnit, StringFormat='Unit: {0}'}" FontSize="12" FontFamily="Calibri" Foreground="White" HorizontalAlignment="Left"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                                <Button Name="AddFlight" Content="Add Flight To My Trip" Width="150" Height="40" Margin="0,10,0,0" Click="AddFlightTrip_Click"/>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
