<Window x:Class="TripRadar.CarsAvailList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TripRadar"
        mc:Ignorable="d"
        Title="Cars Available" Height="450" Width="800">
    <Grid>
        <ScrollViewer>
            <ItemsControl Name="CarsAvailable">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF445F7E" CornerRadius="10" Margin="10,5" Padding="15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True" Height="170">
                                        <Image Source="{Binding Image}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="5">
                                        <TextBlock Text="{Binding CarName, StringFormat=' {0}'}" FontSize="18" Foreground="White" FontWeight="Bold" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding CarType, StringFormat=' City: {0}'}" Foreground="White" FontSize="18" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding Transmission, StringFormat=' Rating: {0}'}" Foreground="Gold" FontSize="18" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding Price, StringFormat=' €{0}' }" Foreground="#FF5AFFE7" FontSize="30" FontWeight="Bold" FontFamily="Calibri"/>
                                        <Button Name="ViewHotel" Content="View Details" HorizontalAlignment="Left" Height="40" Margin="0"/>
                                    </StackPanel>
                                </Grid>
                                <Border Background="White" CornerRadius="10" Padding="10" Margin="10">
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</Window>
