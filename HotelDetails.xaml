<Window x:Class="TripRadar.HotelDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TripRadar"
        mc:Ignorable="d"
        Title="Hotel Details" Height="700" Width="1000" Background="#3f8a88">
    <Grid>
        <ScrollViewer>
            <ItemsControl Name="HotelDetailsPage">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FF445F7E" CornerRadius="10" Margin="10,5" Padding="15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="300"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" CornerRadius="10" ClipToBounds="True" Height="300">
                                        <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="5">
                                        <TextBlock Text="{Binding HotelDetName, StringFormat=' {0}'}" FontSize="30" Foreground="#FF5AFFE7" FontWeight="Bold" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding Address, StringFormat=' Address: {0}'}" Foreground="White" FontSize="18" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding HotelCity, StringFormat=' City: {0}'}" Foreground="White" FontSize="18" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding FromCityCenter, StringFormat=' Distance From City Center: {0}KM'}" Foreground="White" FontSize="18" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding RoomType, StringFormat=' Accomodation Type: {0}'}" Foreground="Gold" FontSize="18" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding AvailableRooms, StringFormat=' Available Rooms: {0}' }" Foreground="#FF5AFFE7" FontSize="20" FontWeight="Bold" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding Arrival, StringFormat=' Check In Date/Time: {0}'}" FontSize="18" Foreground="White" FontFamily="Calibri" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding Departure, StringFormat=' Check Out Date/Time: {0}'}" FontSize="18" Foreground="White" FontFamily="Calibri" FontStyle="Italic"/>
                                        <TextBlock Text="{Binding Facilities, StringFormat=' Family Facilities Include: {0}'}" FontSize="18" Foreground="Gold" FontFamily="Calibri"/>
                                        <TextBlock Text="{Binding PricePNight, StringFormat=' Price Per Night: €{0}'}" FontSize="34" Foreground="#FF5AFFE7" FontFamily="Calibri" FontWeight="Bold"/>
                                        <Button Name="AddHotel" Content="Add To My Trip" HorizontalAlignment="Left" Height="40" Margin="5"/>
                                    </StackPanel>
                                </Grid>
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="10">
                                    <ItemsControl ItemsSource="{Binding Photos}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" ClipToBounds="True" Margin="5" Width="200" Height="150">
                                                    <Image Source="{Binding}" Stretch="UniformToFill"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
