<Window x:Class="TripRadar.FlightResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TripRadar"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Title="Available Flights" Height= "560" Width="800" Background="#3f8a88">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    
    <Grid>
        <ScrollViewer>
            <ItemsControl Name="FlightsItemControl" Width="700" Margin="10,0,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Margin="10,5" Padding="15" BorderBrush="white" BorderThickness="1" Background="#FF445F7E">
                            
                            <StackPanel>
                                <Image Source="{Binding AirlineLogo}" Width="160" Height="160" Margin="0,0,0,0"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#1A2A3A" CornerRadius="10" Padding="10" Margin="5">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="OUTBOUND" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Center"/>
                                            <Image Source="{Binding SmallAirlineLogo}" Width="50" Height="50" Margin="0,0,0,0"/>
                                            <TextBlock Text="{Binding DepartureAirport, StringFormat='Departure: {0}'}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding DepartureTime, StringFormat='Departure Date/Time: {0}'}" Foreground="#FF5AFFE7" FontSize="14"/>
                                            <TextBlock Text="{Binding ArrivalAirport, StringFormat='Arrival: {0}'}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding ArrivalTime, StringFormat='Arrival Date/Time: {0}'}" Foreground="#FF5AFFE7" FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#1A2A3A" CornerRadius="10" Padding="10" Margin="5" Visibility="{Binding IsReturn, Converter={StaticResource BoolToVis}}">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="RETURN" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Center"/>
                                            <Image Source="{Binding SmallAirlineLogo}" Width="50" Height="50" Margin="0,0,0,0"/>
                                            <TextBlock Text="{Binding ReturnDepartureAirport, StringFormat='Departure: {0}'}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding ReturnDepartureTime, StringFormat='Departure Date/Time: {0}'}" Foreground="#FF5AFFE7" FontSize="14"/>
                                            <TextBlock Text="{Binding ReturnArrivalAirport, StringFormat='Arrival: {0}'}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                                            <TextBlock Text="{Binding ReturnArrivalTime, StringFormat='Arrival Date/Time: {0}'}" Foreground="#FF5AFFE7" FontSize="14"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#1A2A3A" CornerRadius="10" Padding="10" Margin="5" HorizontalAlignment="Left">
                                        <StackPanel Margin="5">
                                            <TextBlock Text="PRICING" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Center"/>
                                            <TextBlock Text="{Binding Price, StringFormat='Price: €{0}'}" Foreground="#FF5AFFE7" FontSize="24" FontWeight="Bold"/>
                                            <TextBlock Text="ADDITIONAL FEES MAY APPLY WITH EXTRAS" FontSize="11" Foreground="#888888" FontFamily="Calibri" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" CornerRadius="10" Margin="5" HorizontalAlignment="Left">
                                        <StackPanel Margin="5">
                                            <Button Name="SeeFlight" Content="View Flight Details" Width="150" Height="40" Margin="0,10,0,0" Click="AddFlight_Click"/>
                                        </StackPanel>
                                    </Border>

                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
